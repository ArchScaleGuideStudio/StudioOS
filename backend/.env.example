# WhatsApp Web Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# WhatsApp Session Storage
SESSION_PATH=./sessions

# LocalAuth session id. Change this to start a clean WhatsApp session if an old one is locked.
WHATSAPP_CLIENT_ID=studio-os-test

# Testing safety: force every outgoing WhatsApp message to one number.
WHATSAPP_TEST_RECIPIENT=919372745434
WHATSAPP_FORCE_TEST_RECIPIENT=false

# Logging
LOG_LEVEL=info
